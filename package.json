{
  "name": "@forjd/minimap",
  "version": "1.1.0",
  "description": "Deterministic repository context compiler for coding agents.",
  "keywords": [
    "agents",
    "ai",
    "bun",
    "cli",
    "context",
    "repository"
  ],
  "homepage": "https://github.com/forjd/minimap#readme",
  "bugs": {
    "url": "https://github.com/forjd/minimap/issues"
  },
  "license": "MIT",
  "author": "Forjd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forjd/minimap.git"
  },
  "bin": {
    "minimap": "bin/minimap.js"
  },
  "files": [
    "bin",
    "skills",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "src/cli.ts",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.29.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
